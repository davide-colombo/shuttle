#!/usr/bin/env bash
# shuttle - remote mirror transfer utility
# This is the main entrypoint. Command logic is intentionally stubbed.

set -euo pipefail

SHUTTLE_VERSION="0.2.0"

SHUTTLE_DRY_RUN=0
SHUTTLE_VERBOSE=0
SHUTTLE_PROFILE="default"
SHUTTLE_CONFIG_PATH=""

# Resolve the directory of this script, following symlinks.
resolve_script_dir() {
  local source="${BASH_SOURCE[0]}"
  local dir

  while [[ -L "$source" ]]; do
    dir="$(cd -P "$(dirname "$source")" >/dev/null 2>&1 && pwd)"
    source="$(readlink "$source")"
    [[ "$source" != /* ]] && source="$dir/$source"
  done

  cd -P "$(dirname "$source")" >/dev/null 2>&1 && pwd
}

_shuttle_script_dir="$(resolve_script_dir)"
_shuttle_lib="${_shuttle_script_dir}/../lib/shuttle"
if [[ ! -d "$_shuttle_lib" ]]; then
    _shuttle_lib="${_shuttle_script_dir}/../lib"
fi
if [[ ! -d "$_shuttle_lib" ]]; then
    printf "[shuttle] ERROR lib directory not found\n" >&2
    exit 1
fi

# shellcheck source=/dev/null
source "$_shuttle_lib/config.sh"
# shellcheck source=/dev/null
source "$_shuttle_lib/transfer.sh"
# shellcheck source=/dev/null
source "$_shuttle_lib/log.sh"
# shellcheck source=/dev/null
source "$_shuttle_lib/util.sh"

print_usage() {
  cat <<'USAGE'
Usage:
  shuttle [--dry-run] [--verbose] [--profile <name>] [--config <path>] <subcommand>

Subcommands:
  up
  down
  status
  init
  help
  version
USAGE
}

# ---------------------------------------------------------------------------
# guard_destructive_delete - Warn and require confirmation when delete = yes.
#
# Arguments:
#   $1 - transfer direction ("up" or "down")
#
# Globals read:
#   SHUTTLE_XFER_DELETE    - "yes" or "no"
#   SHUTTLE_DRY_RUN        - "1" if dry-run mode
#   SHUTTLE_XFER_LOCAL_ROOT
#   SHUTTLE_XFER_REMOTE_ROOT
#
# Behaviour:
#   - If delete != yes or dry-run is active, returns immediately (no-op).
#   - Otherwise, prints a warning and prompts the user to type the basename
#     of the destination directory.
#   - If the typed word does not match, aborts with exit 1.
#   - If stdin is not a terminal (piped input), aborts with an error message.
# ---------------------------------------------------------------------------
guard_destructive_delete() {
  local direction="$1"
  local dest_path=""
  local dest_basename=""
  local confirmation=""

  [[ "${SHUTTLE_XFER_DELETE}" != "yes" ]] && return 0
  [[ "${SHUTTLE_DRY_RUN:-0}" == "1" ]] && return 0

  if [[ "$direction" == "up" ]]; then
    dest_path="${SHUTTLE_XFER_REMOTE_ROOT}"
  else
    dest_path="${SHUTTLE_XFER_LOCAL_ROOT}"
  fi

  dest_basename="$(basename "$dest_path")"

  if [[ ! -t 0 ]]; then
    log_error "delete = yes requires interactive confirmation but stdin is not a terminal"
    log_error "Aborting. Run interactively or use --dry-run to preview changes."
    exit 1
  fi

  echo ""
  log_warn "========================================="
  log_warn " DESTRUCTIVE SYNC - delete = yes"
  log_warn "========================================="
  echo ""
  if [[ "$direction" == "up" ]]; then
    log_warn "Direction: LOCAL -> REMOTE"
    log_warn "Source:      ${SHUTTLE_XFER_LOCAL_ROOT}/"
    log_warn "Destination: ${SHUTTLE_XFER_REMOTE_ROOT}/"
  else
    log_warn "Direction: REMOTE -> LOCAL"
    log_warn "Source:      ${SHUTTLE_XFER_REMOTE_ROOT}/"
    log_warn "Destination: ${SHUTTLE_XFER_LOCAL_ROOT}/"
  fi
  echo ""
  log_warn "Files in the DESTINATION that do not exist in the SOURCE will be PERMANENTLY DELETED."
  log_warn "This operation cannot be undone."
  echo ""
  log_warn "To confirm, type the destination folder name: ${dest_basename}"
  echo ""

  printf "  > "
  read -r confirmation

  if [[ "$confirmation" != "$dest_basename" ]]; then
    echo ""
    log_error "Confirmation failed. Expected '${dest_basename}', got '${confirmation}'."
    log_error "Aborting."
    exit 1
  fi

  echo ""
  log_info "Confirmed. Proceeding with destructive sync..."
  echo ""
}

cmd_up() {
  local rc=0
  local conf_path=""
  local conf_dir=""

  if ! config_discover_project; then
    log_die "no .shuttle.conf found from $PWD upward; run 'shuttle init' first"
  fi

  if [[ -n "${SHUTTLE_CONFIG_PATH:-}" ]]; then
    conf_path="${SHUTTLE_CONFIG_PATH}"
    if [[ "${conf_path}" != /* ]]; then
      conf_path="${PWD}/${conf_path}"
    fi
    conf_dir="$(cd -P "$(dirname "${conf_path}")" >/dev/null 2>&1 && pwd)"
    conf_path="${conf_dir}/$(basename "${conf_path}")"
    [[ -f "${conf_path}" ]] || log_die "project config override not found: ${conf_path}"
    SHUTTLE_PROJECT_ROOT="${conf_dir}"
    SHUTTLE_PROJECT_CONF="${conf_path}"
  fi

  config_load_global
  config_load_project
  config_resolve_profile "${SHUTTLE_PROFILE}"

  if [[ "${SHUTTLE_XFER_DIRECTION}" == "down" ]]; then
    log_die "profile '${SHUTTLE_PROFILE}' does not allow uploads (direction=down)"
  fi

  guard_destructive_delete "up"
  transfer_build_cmd up
  set +e
  transfer_exec
  rc=$?
  set -e
  exit "$rc"
}

cmd_down() {
  local rc=0
  local conf_path=""
  local conf_dir=""

  if ! config_discover_project; then
    log_die "no .shuttle.conf found from $PWD upward; run 'shuttle init' first"
  fi

  if [[ -n "${SHUTTLE_CONFIG_PATH:-}" ]]; then
    conf_path="${SHUTTLE_CONFIG_PATH}"
    if [[ "${conf_path}" != /* ]]; then
      conf_path="${PWD}/${conf_path}"
    fi
    conf_dir="$(cd -P "$(dirname "${conf_path}")" >/dev/null 2>&1 && pwd)"
    conf_path="${conf_dir}/$(basename "${conf_path}")"
    [[ -f "${conf_path}" ]] || log_die "project config override not found: ${conf_path}"
    SHUTTLE_PROJECT_ROOT="${conf_dir}"
    SHUTTLE_PROJECT_CONF="${conf_path}"
  fi

  config_load_global
  config_load_project
  config_resolve_profile "${SHUTTLE_PROFILE}"

  if [[ "${SHUTTLE_XFER_DIRECTION}" == "up" ]]; then
    log_die "profile '${SHUTTLE_PROFILE}' does not allow downloads (direction=up)"
  fi

  guard_destructive_delete "down"
  transfer_build_cmd down
  set +e
  transfer_exec
  rc=$?
  set -e
  exit "$rc"
}

cmd_status() {
  local requested_direction="${1:-}"
  local status_direction=""
  local rc=0
  local conf_path=""
  local conf_dir=""

  if ! config_discover_project; then
    log_die "no .shuttle.conf found from $PWD upward; run 'shuttle init' first"
  fi

  if [[ -n "${SHUTTLE_CONFIG_PATH:-}" ]]; then
    conf_path="${SHUTTLE_CONFIG_PATH}"
    if [[ "${conf_path}" != /* ]]; then
      conf_path="${PWD}/${conf_path}"
    fi
    conf_dir="$(cd -P "$(dirname "${conf_path}")" >/dev/null 2>&1 && pwd)"
    conf_path="${conf_dir}/$(basename "${conf_path}")"
    [[ -f "${conf_path}" ]] || log_die "project config override not found: ${conf_path}"
    SHUTTLE_PROJECT_ROOT="${conf_dir}"
    SHUTTLE_PROJECT_CONF="${conf_path}"
  fi

  config_load_global
  config_load_project
  config_resolve_profile "${SHUTTLE_PROFILE}"

  if [[ -n "${requested_direction}" ]]; then
    case "${requested_direction}" in
      up|down) status_direction="${requested_direction}" ;;
      *) log_die "status direction must be 'up' or 'down' (got: ${requested_direction})" ;;
    esac
  else
    case "${SHUTTLE_XFER_DIRECTION}" in
      both) status_direction="up" ;;
      up|down) status_direction="${SHUTTLE_XFER_DIRECTION}" ;;
      *) log_die "invalid profile direction '${SHUTTLE_XFER_DIRECTION}' for status" ;;
    esac
  fi

  set +e
  transfer_status "${status_direction}"
  rc=$?
  set -e
  exit "$rc"
}

cmd_init() {
  local script_dir=""
  local root_dir=""
  local template_conf=""
  local target_conf="${PWD}/.shuttle.conf"
  local global_conf=""

  if [[ -f "${target_conf}" ]]; then
    log_warn ".shuttle.conf already exists at ${target_conf}; leaving it unchanged"
    exit 0
  fi

  script_dir="$(util_resolve_script_dir "${BASH_SOURCE[0]-}")"
  root_dir="$(cd -P "${script_dir}/.." >/dev/null 2>&1 && pwd)"
  template_conf="${root_dir}/share/shuttle/template.shuttle.conf"
  [[ -f "${template_conf}" ]] || log_die "template file not found: ${template_conf}"

  cp "${template_conf}" "${target_conf}"
  log_info "created ${target_conf}"
  log_info "edit .shuttle.conf to set your remote_root and profile options"

  if [[ -n "${SHUTTLE_GLOBAL_CONF:-}" ]]; then
    global_conf="${SHUTTLE_GLOBAL_CONF}"
  else
    global_conf="${XDG_CONFIG_HOME:-$HOME/.config}/shuttle/credentials.env"
  fi

  if [[ ! -f "${global_conf}" ]]; then
    log_info "global credentials file is missing: ${global_conf}"
    log_info "create it with REMOTE_HOST, REMOTE_USER, SSH_PORT[, SSH_KEY] and chmod 600"
  fi

  exit 0
}

cmd_help() {
  cat >&2 <<EOF
shuttle ${SHUTTLE_VERSION}
Usage: shuttle [flags] <command>

Commands:
  init      create .shuttle.conf from template in current directory
  up        sync local changes to remote
  down      sync remote changes to local
  status    show what would transfer (dry-run itemized summary)
  help      show this help
  version   print version

Global flags:
  --dry-run           run rsync without writing changes
  --verbose           enable debug logs
  --profile <name>    use named profile from .shuttle.conf (default: default)
  --config <path>     override project config file path

Config files:
  project: .shuttle.conf (discovered from current directory upward)
  global:  \${XDG_CONFIG_HOME:-\$HOME/.config}/shuttle/credentials.env (mode 600)
EOF
  exit 0
}

cmd_version() {
  printf 'shuttle %s\n' "${SHUTTLE_VERSION}" >&2
  exit 0
}

# Parse global flags before subcommand.
while [[ $# -gt 0 ]]; do
  case "$1" in
    --dry-run)
      SHUTTLE_DRY_RUN=1
      shift
      ;;
    --verbose)
      SHUTTLE_VERBOSE=1
      shift
      ;;
    --profile)
      [[ $# -ge 2 ]] || { echo "Missing value for --profile" >&2; print_usage; exit 1; }
      SHUTTLE_PROFILE="$2"
      shift 2
      ;;
    --config)
      [[ $# -ge 2 ]] || { echo "Missing value for --config" >&2; print_usage; exit 1; }
      SHUTTLE_CONFIG_PATH="$2"
      shift 2
      ;;
    --)
      shift
      break
      ;;
    -*)
      echo "Unknown flag: $1" >&2
      print_usage
      exit 1
      ;;
    *)
      break
      ;;
  esac
done

if [[ $# -lt 1 ]]; then
  print_usage
  exit 1
fi

subcommand="$1"
shift || true

case "$subcommand" in
  up)      cmd_up "$@" ;;
  down)    cmd_down "$@" ;;
  status)  cmd_status "$@" ;;
  init)    cmd_init "$@" ;;
  help)    cmd_help "$@" ;;
  version) cmd_version "$@" ;;
  *)
    echo "Unknown subcommand: $subcommand" >&2
    print_usage
    exit 1
    ;;
esac
